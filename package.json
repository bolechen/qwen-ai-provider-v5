{
  "name": "qwen-ai-provider-v5",
  "type": "commonjs",
  "version": "2.1.1",
  "packageManager": "pnpm@10.2.0",
  "description": "Vercel AI Provider v6 for running Qwen AI models",
  "author": "bolechen <avenger@php.net>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/bolechen/qwen-ai-provider-v5",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bolechen/qwen-ai-provider-v5.git"
  },
  "bugs": {
    "url": "https://github.com/bolechen/qwen-ai-provider-v5/issues"
  },
  "keywords": [
    "qwen",
    "ai",
    "provider",
    "vercel-ai",
    "vercel",
    "ai-sdk v6"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup -d --watch",
    "lint": "eslint \"./**/*.ts*\"",
    "test": "pnpm test:node && pnpm test:edge",
    "test:edge": "vitest --config vitest.edge.config.mjs --run",
    "test:node": "vitest --config vitest.node.config.mjs --run",
    "test:integration": "vitest --config vitest.node.config.mjs --run src/__tests__/integration/",
    "coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "prettier-check": "prettier --check \"./**/*.ts*\"",
    "clean": "rm -rf dist",
    "prepare": "husky",
    "prepack": "pnpm build",
    "ci:release": "pnpm clean && pnpm build && changeset publish",
    "ci:version": "changeset version && pnpm install --no-frozen-lockfile",
    "validate": "pnpm test && pnpm type-check && pnpm lint"
  },
  "peerDependencies": {
    "zod": "^3.25.76 || ^4.1.8"
  },
  "dependencies": {
    "@ai-sdk/provider": "^3.0.8",
    "@ai-sdk/provider-utils": "^4.0.21"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.19.0",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@edge-runtime/vm": "^5.0.0",
    "@types/node": "^22.19.15",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "ai": "^6.0.137",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-plugin-format": "^1.5.0",
    "husky": "^9.1.7",
    "msw": "^2.12.14",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
